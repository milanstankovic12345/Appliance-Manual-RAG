# ─── Backend ──────────────────────────────────────────────────────────────────
# Copy this file to `.env` and adjust values as needed.

# Bind address for the FastAPI backend. Use 0.0.0.0 to make it reachable
# from other machines on the LAN (e.g. behind the nginx reverse proxy).
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Where Ollama is reachable. Default is fine for local installs.
OLLAMA_BASE_URL=http://localhost:11434

# Models to use. The launcher will `ollama pull` these if missing.
# You can change to any chat model you have pulled, e.g. llama3.1, mistral, qwen2.5
OLLAMA_LLM_MODEL=hermes3
OLLAMA_EMBED_MODEL=nomic-embed-text

# Seconds to wait for a single LLM response before giving up.
OLLAMA_REQUEST_TIMEOUT=360

# ─── Storage ──────────────────────────────────────────────────────────────────
# Where uploaded docs and the vector index live. Relative to the project root.
DOCS_DIR=./documents
STORAGE_DIR=./storage

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins that may call the API.
# For local dev: http://localhost:3000
# For LAN/nginx deployment, add your server's IP/hostname, e.g. http://192.168.1.50
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
